<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <FileVersion>3.5.0.0</FileVersion>
        <NoWarn>$(NoWarn);CS1591;RCS1158</NoWarn>
        <TargetFramework>net6.0</TargetFramework>
        <IsPlantsVsZombiesFusion>true</IsPlantsVsZombiesFusion>
    </PropertyGroup>
    <ItemGroup>
        <PackageReference Remove="Emik.Analyzers.Matches"/>
        <Compile Remove="$(Morsels)/Compile/Source/References/**/*.cs"/>
        <Compile Include="$(Morsels)/Compile/Source/References/Emik/Numerics/Clamped.cs" Link="Source/References/Emik/Numerics/Clamped.cs"/>
        <Compile Include="$(Morsels)/Compile/Source/References/System/Diagnostics/Attributes.cs" Link="Source/References/System/Diagnostics/Attributes.cs"/>
        <Compile Include="$(Morsels)/Compile/Source/References/Emik/Collections/Immutable/Bits*.cs" Link="Source/References/Emik/Collections/Immutable/Bits*.cs"/>
    </ItemGroup>
</Project>
